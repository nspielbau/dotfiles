{
  "$schema": "https://opencode.ai/config.json",
  "theme": "github",
  "permission": {
    "*": "ask",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "todowrite": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "question": "allow",
  },
  "bash": {
  "*": "ask",
  "ls *": "allow",
  "ls": "allow",
  "grep *": "allow",
  "git *": "allow",
  "git push --force*": "deny",
  "git push -f*": "deny",
  "git reset --hard*": "ask",
  "git clean -fd*": "ask",
  "rm *": "ask",
  "rm -rf *": "deny"
  },
  "lsp": true,
  "provider": {
    "fzi-llm": {
      "models": {
        "Qwen/Qwen3.5-397B-A17B": {
          "family": "",
          "modalities": {
            "input": [
              "text",
              "video",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "name": "Qwen/Qwen3.5-397B-A17B"
        },
        "coder": {
          "name": "FZI-Coder"
        }
      },
      "name": "FZI-LLM",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://llm.fzi.de/api"
      }
    }
  }
}

